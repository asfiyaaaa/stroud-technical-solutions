# Database (PostgreSQL via Neon)
# Get your connection string from https://neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Site
NEXT_PUBLIC_SITE_URL="https://stroudtechnicalsolutions.com"

# Admin
ADMIN_PASSWORD="change-this-to-a-secure-password"

# Cloudinary (Resume Storage)
# Get your URL from https://cloudinary.com → Dashboard
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"

# Resend (Email Notifications)
# Get your API key from https://resend.com
RESEND_API_KEY="re_xxxxxxxxxx"
EMAIL_FROM="noreply@stroudtechnicalsolutions.com"
EMAIL_TO="Shane@stroudtechnicalsolutions.com"

# Google Maps (optional)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""
